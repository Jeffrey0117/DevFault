    {
      "name": "RePic",
      "url": "https://github.com/Jeffrey0117/RePic.git",
      "postInstall": "npm install"
    },
    {
      "name": "ReVid",
      "url": "https://github.com/Jeffrey0117/ReVid.git",
      "postInstall": "npm install"
    },
    {
      "name": "Ytify",
      "url": "https://github.com/Jeffrey0117/Ytify.git"
    },
    {
      "name": "winbat",
      "url": "https://github.com/Jeffrey0117/winbat.git"
    },
    {
      "name": "ClaudeBot",
      "url": "https://github.com/Jeffrey0117/ClaudeBot.git",
      "postInstall": "npm install"
    },
    {
      "name": "CloudPipe",
      "url": "https://github.com/Jeffrey0117/CloudPipe.git",
      "postInstall": "npm install"
    },
    {
      "name": "Screenshot-OCR",
      "url": "https://github.com/Jeffrey0117/Screenshot-OCR.git",
      "postInstall": "npm install"
    }
  ]
}
