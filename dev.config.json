{
  "baseDir": "~/workspace",
  "tools": [
    { "name": "git",    "cmd": "git",    "winget": "Git.Git" },
    { "name": "node",   "cmd": "node",   "winget": "OpenJS.NodeJS.LTS" },
    { "name": "python", "cmd": "python", "winget": "Python.Python.3.12" },
    { "name": "gh",     "cmd": "gh",     "winget": "GitHub.cli" },
    { "name": "docker", "cmd": "docker", "winget": "Docker.DockerDesktop" },
    { "name": "ffmpeg", "cmd": "ffmpeg", "winget": "Gyan.FFmpeg" },
    { "name": "pnpm",   "cmd": "pnpm",   "winget": "pnpm.pnpm" }
  ],
  "repos": [
    {
      "name": "PyClick",
      "url": "https://github.com/Jeffrey0117/PyClick.git",
      "postInstall": "pip install -r requirements.txt",
      "run": "python tray_clicker.py",
      "logo": "logo.png"
    },
    {
      "name": "RePic",
      "url": "https://github.com/Jeffrey0117/RePic.git",
      "postInstall": "pnpm install",
      "run": "npm run electron:dev",
      "logo": "repic-logo.png"
    },
    {
      "name": "ReVid",
      "url": "https://github.com/Jeffrey0117/ReVid.git",
      "postInstall": "pnpm install",
      "run": "npm run electron:dev",
      "logo": "revid.png"
    },
    {
      "name": "Ytify",
      "url": "https://github.com/Jeffrey0117/Ytify.git",
      "run": "python app.py",
      "logo": "static/logo.png"
    },
    {
      "name": "winbat",
      "url": "https://github.com/Jeffrey0117/winbat.git"
    },
    {
      "name": "ClaudeBot",
      "url": "https://github.com/Jeffrey0117/ClaudeBot.git",
      "postInstall": "pnpm install",
      "run": "npm run dev"
    },
    {
      "name": "CloudPipe",
      "url": "https://github.com/Jeffrey0117/CloudPipe.git",
      "postInstall": "pnpm install",
      "run": "npm start",
      "logo": "LOGO.png"
    },
    {
      "name": "Screenshot-OCR",
      "url": "https://github.com/Jeffrey0117/Screenshot-OCR.git",
      "postInstall": "pnpm install",
      "run": "npm run dev",
      "logo": "mainpic.png"
    }
  ]
}
